{
  "plugins": ["prettier-plugin-tailwindcss"],
  "printWidth": 100,
  "semi": true,
  "singleQuote": true,
  "trailingComma": "all",
  "arrowParens": "always",
  "overrides": [
    {
      "files": ["*.mts", "*.cts", "*.ts", "*.tsx"],
      "options": {
        "parser": "typescript"
      }
    }
  ]
}
