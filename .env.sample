# MySQL connection string
# Local: mysql://myuser:mypass@localhost:3307/pedal
DATABASE_URL=

# Clerk authentication
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Base URL for loading images in the app (full URL prefix, no trailing slash)
# Local: http://localhost:9000/pedalplayground-assets
# Production: https://pedalplayground-assets.s3.us-east-1.amazonaws.com
S3_BASE_URL=

# Custom S3 endpoint for local testing with MinIO only (leave empty in production)
# Local: http://localhost:9000
S3_ENDPOINT=

# AWS credentials for the upload-images script
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
